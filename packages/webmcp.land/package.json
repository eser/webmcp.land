{
  "name": "webmcp.land",
  "version": "0.1.1",
  "description": "Developer toolkit for MCP/WebMCP resources - build, validate, parse, and connect to webmcp.land",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "webmcp-land": "bin/cli.js",
    "webmcp.land": "bin/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./variables": {
      "types": "./dist/variables/index.d.ts",
      "import": "./dist/variables/index.js",
      "require": "./dist/variables/index.cjs"
    },
    "./similarity": {
      "types": "./dist/similarity/index.d.ts",
      "import": "./dist/similarity/index.js",
      "require": "./dist/similarity/index.cjs"
    },
    "./quality": {
      "types": "./dist/quality/index.d.ts",
      "import": "./dist/quality/index.js",
      "require": "./dist/quality/index.cjs"
    },
    "./builder": {
      "types": "./dist/builder/index.d.ts",
      "import": "./dist/builder/index.js",
      "require": "./dist/builder/index.cjs"
    },
    "./parser": {
      "types": "./dist/parser/index.d.ts",
      "import": "./dist/parser/index.js",
      "require": "./dist/parser/index.cjs"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "webmcp",
    "model-context-protocol",
    "ai",
    "llm",
    "ai-agents",
    "openai",
    "anthropic",
    "claude",
    "mcp-server",
    "mcp-client",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eser/webmcp.land.git"
  },
  "homepage": "https://webmcp.land",
  "author": "Eser Ozvataf <eser@acikyazilim.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs": "node scripts/generate-docs.ts",
    "docs:generate": "node scripts/generate-docs.ts"
  },
  "dependencies": {
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-select-input": "^6.0.0",
    "react": "^18.3.1",
    "clipboardy": "^4.0.0",
    "meow": "^13.2.0",
    "open": "^10.1.0",
    "terminal-image": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5",
    "vitest": "^4.0.16"
  }
}
